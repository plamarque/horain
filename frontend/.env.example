# =============================================================================
# Horain Frontend - Environment variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Vite only exposes variables prefixed with VITE_ to the client.
#
# Where to configure:
#   - Local dev: copy to .env in this directory
#   - Production (GitHub Pages): GitHub Repository Secrets (see docs/ENV_SETUP.md)
# =============================================================================

# -----------------------------------------------------------------------------
# VITE_API_URL
# -----------------------------------------------------------------------------
# Backend API base URL (no trailing slash).
#   Local:    http://localhost:8080
#   Prod:     https://your-app-name.onrender.com (your Render backend URL)
# Where: Local = .env | GitHub Actions = Repository Secret VITE_API_URL
VITE_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# VITE_API_KEY
# -----------------------------------------------------------------------------
# API key for Authorization: Bearer header.
# Must match HORAIN_API_KEY on the backend (Render env vars).
# Where: Local = .env | GitHub Actions = Repository Secret VITE_API_KEY
VITE_API_KEY=HORAIN_DEV_KEY
