# =============================================================================
# Horain Backend - Environment variables (for Render / local reference)
# =============================================================================
# Spring Boot reads these from the environment. Render injects them automatically.
# For local dev with PostgreSQL, export these or use a script that loads them.
#
# Where to configure:
#   - Render: Environment tab in your Web Service dashboard
#   - Local:  export before mvn spring-boot:run, or use a loader script
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# From Supabase: Project Settings > Database > Connection string (URI)
# Use "Transaction" or "Session" mode. Format:
#   jdbc:postgresql://db.PROJECT_REF.supabase.co:5432/postgres
# Where: Render = Environment variables
SPRING_DATASOURCE_URL=jdbc:postgresql://db.xxxx.supabase.co:5432/postgres

# Database user (Supabase: Project Settings > Database)
# Where: Render = Environment variables
SPRING_DATASOURCE_USERNAME=postgres

# Database password (Supabase: Project Settings > Database)
# Where: Render = Environment variables
SPRING_DATASOURCE_PASSWORD=your_supabase_password

# -----------------------------------------------------------------------------
# Spring profile
# -----------------------------------------------------------------------------
# Use postgres profile in production (uses PostgreSQL dialect and config)
# Where: Render = Environment variables
SPRING_PROFILES_ACTIVE=postgres

# -----------------------------------------------------------------------------
# HORAIN_API_KEY
# -----------------------------------------------------------------------------
# API key for authenticating frontend requests (Authorization: Bearer).
# Must match VITE_API_KEY used by the frontend.
# Where: Render = Environment variables
HORAIN_API_KEY=HORAIN_DEV_KEY

# -----------------------------------------------------------------------------
# OPENAI_API_KEY (future use - Spring AI agent)
# -----------------------------------------------------------------------------
# Create at https://platform.openai.com/api-keys
# Required when the LLM agent is integrated (Slice 3+).
# Where: Render = Environment variables
OPENAI_API_KEY=sk-your-openai-api-key
